# Estado interno de plugins/herramientas locales
.omc/
.claude/

# ============================================================
# DATOS OPERATIVOS - NUNCA se versionan (este repo es PUBLICO)
# ============================================================
# El inventario real y las salidas del monitor contienen IPs de
# Tailscale, hosts, puertos y el estado de la infraestructura.
# En un repo publico eso NO puede salir: vive solo en este PC.
# Hermes recibe el inventario por otra via (chat / puente), nunca
# desde el repo publico.
config/ecosistema.json
estado/*
!estado/.gitkeep
reportes/*
!reportes/.gitkeep
